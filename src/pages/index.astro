---
import Base from '../layouts/Base.astro';
---
<Base title="Phalanx Racing">
  <div class="wrap page" style="text-align:center;min-height:70vh;display:flex;flex-direction:column;justify-content:center">
    <span class="eyebrow">TEKNOFEST 2027 · Efficiency Challenge</span>
    <h1 style="font-size:clamp(44px,9vw,90px)"><span class="gold">PHALANX</span> RACING</h1>
    <p class="lead" style="margin:14px auto 30px">Sıfırdan bir elektrikli verimlilik aracı inşa eden, disiplinler arası bir öğrenci takımı.</p>
    <div>
      <a class="back" href="/build-log" style="border:1px solid var(--gold);padding:12px 24px">Build-log →</a>
    </div>
  </div>
</Base>