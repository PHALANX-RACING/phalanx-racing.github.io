---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('buildlog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = (d) => d.toLocaleDateString('tr-TR', { day: 'numeric', month: 'long', year: 'numeric' });
---
<Base title="Build-log — Phalanx Racing" desc="Phalanx Racing yarış aracı geliştirme günlüğü — tarih tarih ilerleme: eğitim, tasarım, üretim ve test adımları.">
  <div class="wrap page">
    <span class="eyebrow">Sahadan</span>
    <h1>Build-log</h1>
    <p class="lead">Atölyeden yarış pistine yolculuğumuz — tarih tarih, adım adım.</p>

    <div class="timeline">
      {posts.map((p) => (
        <a class="tl-item" href={`/build-log/${p.id}/`}>
          <div class="tl-date">{fmt(p.data.date)}{p.data.tag ? ` · ${p.data.tag}` : ''}</div>
          <h3 class="tl-h">{p.data.title}</h3>
          <p class="tl-p">{p.data.summary}</p>
        </a>
      ))}
    </div>
  </div>

<style>
.timeline{position:relative;margin-top:26px;padding-left:34px}
.timeline::before{content:"";position:absolute;left:6px;top:8px;bottom:12px;width:2px;background:linear-gradient(180deg,var(--gold) 0%,rgba(188,131,41,.15) 100%)}
.tl-item{position:relative;display:block;padding-bottom:34px;color:inherit;text-decoration:none}
.tl-item::before{content:"";position:absolute;left:-34px;top:4px;width:14px;height:14px;border-radius:50%;background:linear-gradient(135deg,#F0ED72,#BC8329);box-shadow:0 0 0 4px var(--bg)}
.tl-item:last-child{padding-bottom:6px}
.tl-date{font-family:'Chakra Petch';font-size:12px;letter-spacing:.12em;text-transform:uppercase;color:var(--gold)}
.tl-h{font-family:'Chakra Petch';font-size:19px;text-transform:uppercase;font-weight:600;margin:5px 0 6px;color:var(--cream);transition:color .2s}
.tl-item:hover .tl-h{color:var(--yellow)}
.tl-p{font-size:14px;color:var(--muted);max-width:640px}
</style>
</Base>
